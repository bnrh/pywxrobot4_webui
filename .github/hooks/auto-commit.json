{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "python .github/hooks/scripts/copilot_auto_commit.py UserPromptSubmit",
        "windows": "python .github\\hooks\\scripts\\copilot_auto_commit.py UserPromptSubmit",
        "cwd": ".",
        "timeout": 15
